      "scripts": {
            "dev": "vite",
            "build": "vite build",
            "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives --max-warnings 2",
            "lint:fix": "eslint src --ext .ts,.tsx --fix",
            "typecheck": "tsc --noEmit",
            "cap:sync": "npx cap sync",
            "cap:open:ios": "npx cap open ios",
            "cap:open:android": "npx cap open android",
            "env:local": "node scripts/create-env-local.js",
            "docker:appwrite:up": "docker compose --env-file infra/appwrite/.env up -d",
            "docker:appwrite:down": "docker compose down",
            "docker:appwrite:logs": "docker compose --env-file infra/appwrite/.env logs -f --tail=100",
            "docker:appwrite:ps": "docker compose --env-file infra/appwrite/.env ps",
            "docker:appwrite:verify": "bash scripts/verify-appwrite-docker.sh",
            "docker:local-dev:up": "docker compose -f docker-compose.legacy.yml --profile local-dev up -d --build",
            "docker:local-dev:down": "docker compose -f docker-compose.legacy.yml --profile local-dev down",
            "docker:local-dev:logs": "docker compose -f docker-compose.legacy.yml --profile local-dev logs -f --tail=100",
            "docker:local-dev:ps": "docker compose -f docker-compose.legacy.yml --profile local-dev ps",
            "docker:local-dev:verify": "bash scripts/verify-local-dev-stack.sh",
            "verify:test-env": "node scripts/verify-appwrite-test-env.mjs",
            "appwrite:env:generate": "node scripts/generate-infra-appwrite-env.mjs",
            "appwrite:functions:create": "bash scripts/appwrite-create-functions.sh",
            "appwrite:deploy:shots": "bash scripts/deploy-appwrite-function-shots.sh",
            "appwrite:provision:schema": "npm run provision-schema --prefix functions",
            "appwrite:provision:buckets": "node functions/tools/provision-appwrite-buckets.mjs",
            "appwrite:delete:collection": "node functions/tools/delete-appwrite-collection.mjs",
            "appwrite:sync:function-domains": "node scripts/sync-vite-function-domain-map.mjs"
      }
}
