# =============================================================================
# Variables for Docker Compose substitution (OPTIONAL local-dev stack only).
# Usage: copy to .env in repo root, then:
#   docker compose --profile local-dev up -d --build
# NOT for Nhost production — see docs/SOURCE_OF_TRUTH.md
# =============================================================================

POSTGRES_USER=scriptony
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=scriptony

HASURA_ADMIN_SECRET=change_me_admin_secret
# Hasura JWT is set in docker-compose.yml (fixed JSON). Override via docker-compose.override.yml if needed.

# Optional
# HASURA_EXTERNAL_URL=https://hasura.yourdomain.com
# POSTGRES_EXTERNAL_URL=postgres://...
