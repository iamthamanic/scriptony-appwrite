# PostgreSQL Configuration
POSTGRES_USER=scriptony
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=scriptony

# Hasura Configuration
HASURA_ADMIN_SECRET=change_me_admin_secret
# JWT for Hasura: set in docker-compose.override.yml as HASURA_GRAPHQL_JWT_SECRET (JSON string).
# Do not rely on HASURA_JWT_SECRET in .env for compose substitution — colons break ${VAR:-default}.

# Optional: External Access
# HASURA_EXTERNAL_URL=https://hasura.yourdomain.com
# POSTGRES_EXTERNAL_URL=postgres://...
