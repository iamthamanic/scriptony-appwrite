# =============================================================================
# Variables for Docker Compose substitution (OPTIONAL legacy local-dev stack only).
# Usage: copy to .env in repo root, then:
#   docker compose -f docker-compose.legacy.yml --profile local-dev up -d --build
# NOT for Appwrite production — see docs/SOURCE_OF_TRUTH.md
# =============================================================================

POSTGRES_USER=scriptony
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=scriptony

# Admin secret for the optional local-dev GraphQL engine container (see docker-compose.legacy.yml `local_graphql_console`).
HASURA_ADMIN_SECRET=change_me_admin_secret
# Engine JWT is set in docker-compose.legacy.yml (fixed JSON). Override via docker-compose.override.yml if needed.
# POSTGRES_EXTERNAL_URL=postgres://...
