# =============================================================================
# Frontend environment (canonical) — Nhost Auth + GraphQL + Storage + Functions
# Full architecture: docs/SOURCE_OF_TRUTH.md
# The production app uses NhostAuthAdapter, not Lucia (backend/auth is local-dev only).
# =============================================================================

# Subdomain + Region: Nhost project Overview (not Settings → General)
VITE_NHOST_SUBDOMAIN=
VITE_NHOST_REGION=eu-central-1

# Self-hosted Nhost: set explicit URLs instead of subdomain (or in addition)
# VITE_NHOST_AUTH_URL=https://auth.example.com/v1
# VITE_NHOST_GRAPHQL_URL=https://graphql.example.com/v1
# VITE_NHOST_STORAGE_URL=https://storage.example.com/v1
# VITE_NHOST_FUNCTIONS_URL=https://functions.example.com/v1

# Web app URL (must match Nhost Auth redirect allowlist)
# Vite dev server port is 3000 (see vite.config.ts)
VITE_APP_WEB_URL=http://localhost:3000
VITE_AUTH_REDIRECT_URL=http://localhost:3000
VITE_PASSWORD_RESET_REDIRECT_URL=http://localhost:3000/reset-password

# Optional: override Functions base (defaults to Nhost functions URL from subdomain)
# VITE_BACKEND_API_BASE_URL=
# VITE_BACKEND_PUBLIC_TOKEN=

# Capacitor (mobile builds only)
VITE_CAPACITOR_APP_ID=ai.scriptony.app
VITE_CAPACITOR_URL_SCHEME=scriptony
VITE_CAPACITOR_CALLBACK_HOST=auth-callback
