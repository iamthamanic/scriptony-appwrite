# Copy to .env.migration (or .env) and fill in. Never commit .env.migration or .env.
# Place in Scriptonyapp/ or Scriptonyapp/scripts/

# Supabase (Service Role Key from Dashboard → Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Nhost (from Nhost Dashboard → Settings → API)
NHOST_GRAPHQL_URL=https://YOUR_SUBDOMAIN.REGION.nhost.run/v1/graphql
NHOST_ADMIN_SECRET=
NHOST_STORAGE_URL=https://YOUR_SUBDOMAIN.REGION.nhost.run/v1/storage

# Optional: path to user-id mapping (default: scripts/user-id-mapping.json)
# USER_ID_MAPPING_PATH=./scripts/user-id-mapping.json
