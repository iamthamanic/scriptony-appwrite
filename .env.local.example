# Copy to .env.local (not committed). Vite dev uses port 3000 — see vite.config.ts.
# Point hosts at your VPS: scripts/macos-override-nhost-local-hosts.sh

VITE_NHOST_SUBDOMAIN=
VITE_NHOST_REGION=eu-central-1

VITE_NHOST_AUTH_URL=http://local.auth.local.nhost.run/v1
VITE_NHOST_GRAPHQL_URL=http://local.graphql.local.nhost.run/v1
VITE_NHOST_STORAGE_URL=http://local.storage.local.nhost.run/v1
VITE_NHOST_FUNCTIONS_URL=http://local.functions.local.nhost.run/v1

VITE_APP_WEB_URL=http://localhost:3000
VITE_AUTH_REDIRECT_URL=http://localhost:3000
VITE_PASSWORD_RESET_REDIRECT_URL=http://localhost:3000/reset-password
